{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": false,
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Small",
					"slug": "40",
					"size": "1rem"
				},
				{
					"name": "Medium",
					"slug": "50",
					"size": "1.5rem"
				},
				{
					"name": "Large",
					"slug": "60",
					"size": "2rem"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"dropCap": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"lineHeight": true,
			"textDecoration": true,
			"textTransform": true,
			"customFontSize": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"layout": {
			"contentSize": "840px",
			"wideSize": "1340px"
		},
		"color": {
			"defaultPalette": true,
			"custom": true,
			"link": true
		}
	}
}
