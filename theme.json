{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"link": true,
			"palette": [
				{
					"color": "#f8fafc",
					"name": "Background",
					"slug": "background"
				},
				{
					"color": "#ffffff",
					"name": "Panel",
					"slug": "panel"
				},
				{
					"color": "#334155",
					"name": "Foreground",
					"slug": "foreground"
				},
				{
					"color": "#64748b",
					"name": "Muted",
					"slug": "muted"
				},
				{
					"color": "#e2e8f0",
					"name": "Border",
					"slug": "border"
				},
				{
					"color": "#0ea5e9",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#38bdf8",
					"name": "Primary Light",
					"slug": "primary-light"
				},
				{
					"color": "#0284c7",
					"name": "Primary Dark",
					"slug": "primary-dark"
				},
				{
					"color": "#f59e0b",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#fbbf24",
					"name": "Accent Light",
					"slug": "accent-light"
				},
				{
					"color": "#d97706",
					"name": "Accent Dark",
					"slug": "accent-dark"
				},
				{
					"color": "#22c55e",
					"name": "Success",
					"slug": "success"
				},
				{
					"color": "#ef4444",
					"name": "Danger",
					"slug": "danger"
				},
				{
					"color": "#f59e0b",
					"name": "Warning",
					"slug": "warning"
				},
				{
					"color": "#0ea5e9",
					"name": "Info",
					"slug": "info"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": true,
			"dropCap": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"lineHeight": true,
			"textDecoration": true,
			"textTransform": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Noto Sans JP\", \"Hiragino Sans\", \"Hiragino Kaku Gothic ProN\", \"Yu Gothic\", \"Meiryo\", sans-serif",
					"name": "Sans Serif",
					"slug": "sans"
				},
				{
					"fontFamily": "\"JetBrains Mono\", \"Fira Code\", \"Source Code Pro\", \"Menlo\", \"Consolas\", monospace",
					"name": "Monospace",
					"slug": "mono"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Extra Small",
					"size": "0.75rem",
					"slug": "x-small"
				},
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": {
						"min": "1rem",
						"max": "1.0625rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					},
					"name": "Large",
					"size": "1.125rem",
					"slug": "large"
				},
				{
					"fluid": {
						"min": "1.25rem",
						"max": "1.5rem"
					},
					"name": "Extra Large",
					"size": "1.25rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"min": "1.5rem",
						"max": "1.875rem"
					},
					"name": "2X Large",
					"size": "1.5rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"min": "1.875rem",
						"max": "2.25rem"
					},
					"name": "3X Large",
					"size": "1.875rem",
					"slug": "xxx-large"
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "0.75rem",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "1rem",
					"slug": "40"
				},
				{
					"name": "Medium",
					"size": "1.5rem",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "2rem",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "3rem",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "4rem",
					"slug": "80"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"layout": {
			"contentSize": "840px",
			"wideSize": "1280px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Small",
					"slug": "sm",
					"shadow": "0 1px 2px rgba(0,0,0,0.05)"
				},
				{
					"name": "Medium",
					"slug": "md",
					"shadow": "0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04)"
				},
				{
					"name": "Large",
					"slug": "lg",
					"shadow": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04)"
				}
			]
		},
		"custom": {
			"lineHeight": {
				"body": 1.9,
				"heading": 1.3
			},
			"letterSpacing": {
				"body": "0.02em",
				"heading": "-0.02em"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "var(--wp--custom--line-height--body)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					}
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "600",
					"lineHeight": "var(--wp--custom--line-height--heading)",
					"letterSpacing": "var(--wp--custom--letter-spacing--heading)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "#ffffff"
				},
				"border": {
					"radius": "0.5rem"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)"
					}
				}
			}
		},
		"blocks": {
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)"
				},
				"color": {
					"background": "var(--wp--preset--color--panel)"
				},
				"border": {
					"radius": "0.5rem"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--primary)",
					"width": "0 0 0 4px"
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--50)"
					}
				}
			}
		}
	}
}
